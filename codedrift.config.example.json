{
  "$schema": "https://json-schema.org/draft-07/schema#",

  "exclude": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.js",
    "**/*.spec.js",
    "__tests__/**",
    "test/**",
    "tests/**",
    ".next/**",
    "out/**",
    "__generated__/**",
    "generated/**"
  ],

  "rules": {
    "stack-trace-exposure": "error",
    "hallucinated-deps": "error",
    "missing-await": "error",
    "async-foreach": "error",
    "empty-catch": "warn",
    "hardcoded-secret": "error",
    "unsafe-regex": "error",
    "console-in-production": "warn",
    "missing-input-validation": "error",
    "idor": "error"
  },

  "failOn": "error",

  "excludeTestFiles": false,

  "confidenceThreshold": "medium",

  "respectGitignore": true,

  "cache": {
    "enabled": true,
    "ttl": 86400000
  },

  "format": "terminal",

  "output": null
}
