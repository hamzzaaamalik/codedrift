  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "ora": "^9.3.0",
    "safe-regex2": "^5.0.0",
    "simple-git": "^3.32.3",
    "typescript": "^5.9.3"
  }
